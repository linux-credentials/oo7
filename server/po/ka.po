#: ../src/gnome/prompter.rs:151
msgid "Change Keyring Password"
msgstr "ბრელოკის პაროლის შეცვლა"

#: ../src/gnome/prompter.rs:152
#, rust-format
msgid "Choose a new password for the “{}” keyring"
msgstr "აირჩიეთ ახალი პაროლი ბრელოკისთვის \"{}\""

#: ../src/gnome/prompter.rs:155 ../src/prompt/mod.rs:396
#, rust-format
msgid ""
"An application wants to change the password for the “{}” keyring. Choose the "
"new password you want to use for it."
msgstr "აპლიკაციას ბრელოკის \"{}\" პაროლის შეცვლა უნდა. აირჩიეთ ახალი პაროლი."

#: ../src/gnome/prompter.rs:160
msgid "This operation cannot be reverted"
msgstr "ეს ოპერაცია შეუქცევადია"

#: ../src/gnome/prompter.rs:166
msgid "Continue"
msgstr "გაგრძელება"

#: ../src/gnome/prompter.rs:167 ../src/gnome/prompter.rs:193
#: ../src/gnome/prompter.rs:215
msgid "Cancel"
msgstr "გაუქმება"

#: ../src/gnome/prompter.rs:177
msgid "Unlock Keyring"
msgstr "ბრელოკის განბლოკვა"

#: ../src/gnome/prompter.rs:178
msgid "Authentication required"
msgstr "აუცილებელია ავთენტიკაცია"

#: ../src/gnome/prompter.rs:181 ../src/prompt/mod.rs:386
#, rust-format
msgid "An application wants access to the keyring “{}”, but it is locked"
msgstr "აპლიკაციას სურს წვდომა ბრელოკთან \"{}\", მაგრამ ის ჩაკეტილია"

#: ../src/gnome/prompter.rs:192
msgid "Unlock"
msgstr "განბლოკვა"

#: ../src/gnome/prompter.rs:199
msgid "New Keyring Password"
msgstr "ბრელოკის ახალი პაროლი"

#: ../src/gnome/prompter.rs:200
msgid "Choose password for new keyring"
msgstr "აირჩიეთ ახალი ბრელოკის პაროლი"

#: ../src/gnome/prompter.rs:203 ../src/prompt/mod.rs:391
#, rust-format
msgid ""
"An application wants to create a new keyring called “{}”. Choose the "
"password you want to use for it."
msgstr ""
"აპლიკაციას სურს ახალი ბრელოკის, სახელად \"{}\" შექმნა. აირჩიეთ მისი პაროლი."

#: ../src/gnome/prompter.rs:214
msgid "Create"
msgstr "შექმნა"

#, rust-format
#~ msgid ""
#~ "An application wants to create a new keyring called '{}'. Choose the "
#~ "password you want to use for it."
#~ msgstr ""
#~ "აპლიკაციას სურს ახალი ბრელოკის, სახელად \"{}\" შექმნა. აირჩიეთ მისი "
#~ "პაროლი."

#, rust-format
#~ msgid ""
#~ "An application wants to change the password for the '{}' keyring. Choose "
#~ "the new password you want to use for it."
#~ msgstr ""
#~ "აპლიკაციას სურს ბრელოკის \"{}\" პაროლის შეცვლა. აირჩიეთ ახალი პაროლი, "
#~ "რომელიც გნებავთ, გამოიყენოთ."
